{
  "info": {
    "name": "Comandas de Restaurantes",
    "description": "Colección Postman para el MVP Spring Cloud — API Gateway en :8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/usuarios"
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/productos"
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Lomo saltado\",\n  \"precio\": 28.50,\n  \"estacion\": \"COCINA\"\n}"
            },
            "url": "{{baseUrl}}/productos"
          }
        }
      ]
    },
    {
      "name": "Mesas",
      "item": [
        {
          "name": "Listar mesas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/mesas"
          }
        },
        {
          "name": "Crear mesa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capacidadSillas\": 4\n}"
            },
            "url": "{{baseUrl}}/mesas"
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Simular pedido (Feign demo)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pedidos/simular/1?cantidad=2",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos", "simular", "1"],
              "query": [{ "key": "cantidad", "value": "2" }]
            }
          }
        }
      ]
    },
    {
      "name": "Cocina",
      "item": [
        {
          "name": "Comandas pendientes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/comandas/pendientes"
          }
        }
      ]
    },
    {
      "name": "Público (QR)",
      "item": [
        {
          "name": "Info local",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/publico/local"
          }
        }
      ]
    }
  ]
}
